@page
@using System.Runtime.CompilerServices
@model ChopNShop.Pages.Ingredients.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Ingredient</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ingredient.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ingredient.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ingredient.EntryDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ingredient.EntryDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ingredient.Inclusions)
        </dt>
        <dd class="col-sm-10">
            <table class="table">
                <tr>
                    <th>Recipe</th>
                    <th>Servings</th>
                    <th>Amount</th>
                    <th>Unit</th>
                </tr>
                @foreach (var item in Model.Ingredient.Inclusions)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.Recipe.Title)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Recipe.Servings)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Amount)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Unit)
                        </td>
                    </tr>
                }
            </table>
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Ingredient.ID">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
