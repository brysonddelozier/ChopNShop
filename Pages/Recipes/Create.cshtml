@page
@model ChopNShop.Pages.Recipes.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Recipe</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Recipe.RecipeID" class="control-label"></label>
                <input asp-for="Recipe.RecipeID" class="form-control" />
                <span asp-validation-for="Recipe.RecipeID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Recipe.Title" class="control-label">Recipe Name</label>
                <input asp-for="Recipe.Title" class="form-control" />
                <span asp-validation-for="Recipe.Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Recipe.Servings" class="control-label"></label>
                <input asp-for="Recipe.Servings" class="form-control" />
                <span asp-validation-for="Recipe.Servings" class="text-danger"></span>
            </div>
            <div id="ingredient-list">
                <div class="row ingredient-row mb-2 align-items-center">
                    <div class="col-2">
                        <input type="number" name="IngredientAmounts" class="form-control" placeholder="Amount" />
                    </div>
                    <div class="col-3">
                        <input type="text" name="IngredientUnits" class="form-control" placeholder="Unit (cup, lb...)" />
                    </div>
                    <div class="col-5">
                        <input type="text" name="IngredientNames" class="form-control" placeholder="Ingredient Name" />
                    </div>
                </div>
            </div>
            <button type="button" class="btn btn-secondary mt-2" id="add-ingredient" onclick="addIngredientRow()">+ Add Ingredient</button>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
    function addIngredientRow(){
        const list = document.getElementById("ingredient-list");
            const row = document.createElement("div");
            row.className = "row mb-2 ingredient-row align-items-center";
            // innerHTML lets us insert a whole chunk of HTML at once as a
            // template string, rather than building each element one by one.
            row.innerHTML = `
                <div class="col-2">
                    <input type="number" name="IngredientAmounts" class="form-control qty-input" placeholder="Amount" inputmode="numeric" />
                </div>
                <div class="col-3">
                    <input type="text" name="IngredientUnits" class="form-control" placeholder="Unit (cup, lb...)" />
                </div>
                <div class="col-5">
                    <input type="text" name="IngredientNames" class="form-control ing-name-input" placeholder="Ingredient name" />
                </div>
            `;
            list.appendChild(row);
    }
    </script>
}
